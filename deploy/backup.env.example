# /etc/aldaro/backup.env — Aldaro DB backup configuration
#
# Copy to /etc/aldaro/backup.env and fill in values.

DATABASE_URL=postgres://aldaro:PASSWORD@localhost:5432/aldaro
BACKUP_S3_BUCKET=aldaro-db-backups
BACKUP_S3_PREFIX=backups/
AWS_DEFAULT_REGION=us-east-1

# Optional: encrypt dumps at rest (in addition to S3 SSE)
# BACKUP_ENCRYPT_KEY=your-256-bit-key-here

# Optional: local staging directory
# BACKUP_LOCAL_DIR=/tmp/aldaro-backups

# Optional: days to keep local copies
# BACKUP_RETENTION_DAYS=7

generator client {
  provider = "prisma-client-js"
}

// NOTE: Prisma migrations targeting Postgres are the source of truth.
// SQLite is only for local development without Docker.
// In production, use PostgreSQL.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  accountStatus String    @default("ACTIVE")
  paymentStatus String    @default("NONE")
  role          String    @default("CUSTOMER")
  lastReauthAt  DateTime?

  // Password reset fields
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?

  stripeCustomerId             String?
  stripeDefaultPaymentMethodId String?
  maxActiveWorkspaces          Int     @default(1)
  maxConcurrentRuns            Int     @default(2)
  dailyRuntimeLimitMinutes     Int     @default(360)
  dailySpendLimitSeconds       Int     @default(86400)
  launchesPerHourLimit         Int     @default(3)
  isAlphaTester                Boolean @default(false)

  // Manual customer approval (Author reviews applications)
  customerAccessStatus      String    @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED | SUSPENDED
  customerAccessUpdatedAt   DateTime?
  customerAccessUpdatedById String?
  customerAccessReason      String?

  workspaces                     Workspace[]
  customerApplications           CustomerApplication[]           @relation("ApplicationUser")
  emailOutboxRecipient           EmailOutbox[]                   @relation("EmailOutboxRecipient")
  customerAccessUpdatedBy        User?                           @relation("CustomerAccessUpdatedBy", fields: [customerAccessUpdatedById], references: [id])
  usageSessions                  UsageSession[]
  auditEvents                    SecurityLog[]
  postsCreated                   AuthorPost[]                    @relation("CreatedBy")
  postsUpdated                   AuthorPost[]                    @relation("UpdatedBy")
  revisions                      AuthorPostRevision[]
  banners                        AppBanner[]
  authorAudit                    AuthorAudit[]
  projects                       Project[]
  runs                           Run[]
  githubInstallations            GitHubInstallation[]
  usersReviewedAsAuthor          User[]                          @relation("CustomerAccessUpdatedBy")
  applicationsReviewed           CustomerApplication[]           @relation("ReviewedBy")
  workloadRecommendationRequests WorkloadRecommendationRequest[] @relation("WorkloadRecommendationRequestUser")
  pricingSuggestionsApplied      PricingSuggestion[]             @relation("PricingSuggestionAppliedBy")
  launchOperations               WorkspaceLaunchOperation[]
  workspaceMeterEvents           WorkspaceMeterEventOutbox[]

  // Organizations
  orgMemberships        OrgMembership[] @relation("OrgMembershipUser")
  orgMembershipsInvited OrgMembership[] @relation("OrgMembershipInvitedBy")
  orgInvitationsSent    OrgInvitation[] @relation("OrgInvitationInvitedBy")

  // Developer API
  apiKeys               ApiKey[]
  webhookEndpoints      WebhookEndpoint[]

  // Persistent Volumes
  persistentVolumes     PersistentVolume[]

  // Custom Docker Image Registry Credentials
  imageRegistryCredentials ImageRegistryCredential[]

  // Exposed Ports
  exposedPorts              ExposedPort[]

  // Support Tickets
  supportTickets            SupportTicket[]
  ticketMessages            TicketMessage[]

  // Budget Alerts
  monthlySoftLimitCents     Int?      // monthly soft budget limit in cents
  hardLimitAction           String    @default("ALERT") // ALERT | AUTO_TERMINATE
  lastBudgetAlertAt         DateTime?

  @@map("users")
}

model CustomerApplication {
  id                   String    @id @default(cuid())
  userId               String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  submittedAt          DateTime  @default(now())
  reviewedAt           DateTime?
  reviewedById         String?
  decision             String? // APPROVED | REJECTED
  decisionReason       String?
  internalNotes        String?
  fullName             String
  email                String
  company              String?
  useCase              String?
  expectedGpuTypes     String?
  expectedHoursPerWeek Int?
  regionPreference     String?
  website              String?
  referralSource       String?

  user        User          @relation("ApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy  User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  emailOutbox EmailOutbox[]

  @@index([userId])
  @@index([decision, submittedAt])
  @@index([reviewedAt])
  @@map("customer_applications")
}

model EmailOutbox {
  id                String    @id @default(cuid())
  type              String // APPLICATION_IN_REVIEW | APPLICATION_ACCEPTED | APPLICATION_REJECTED
  toEmail           String
  userId            String?
  applicationId     String?
  subject           String
  bodyText          String
  bodyHtml          String?
  status            String    @default("PENDING") // PENDING | SENDING | SENT | FAILED
  attemptCount      Int       @default(0)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  providerMessageId String?
  dedupeKey         String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  application CustomerApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  recipient   User?                @relation("EmailOutboxRecipient", fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@map("email_outbox")
}

model WorkloadRecommendationRequest {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  userId              String?
  inputText           String
  parsedJson          String?
  recommendationsJson String?
  chosenGpuType       String?
  chosenTemplateId    String?
  latencyMs           Int?
  errorCode           String?

  user User? @relation("WorkloadRecommendationRequestUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("workload_recommendation_requests")
}

model FleetDailyAgg {
  id                String   @id @default(cuid())
  date              DateTime
  gpuType           String
  gpuCount          Int      @default(0)
  gpuHoursAvailable Decimal  @default(0)
  gpuHoursUsed      Decimal  @default(0)
  utilizationPct    Decimal  @default(0)
  revenueUsd        Decimal  @default(0)
  sessionsCount     Int      @default(0)
  uniqueCustomers   Int      @default(0)
  newSignups        Int      @default(0)
  newApprovals      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, gpuType])
  @@index([date])
  @@index([gpuType])
  @@map("fleet_daily_aggs")
}

model PricingSuggestion {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  gpuType         String
  currentRate     Decimal
  suggestedRate   Decimal
  reason          String
  inputsJson      String?
  status          String    @default("NEW") // NEW | DISMISSED | APPLIED
  appliedByUserId String?
  appliedAt       DateTime?

  appliedBy User? @relation("PricingSuggestionAppliedBy", fields: [appliedByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([gpuType])
  @@index([status])
  @@map("pricing_suggestions")
}

model GitHubInstallation {
  id             String   @id @default(uuid())
  userId         String
  installationId String   @unique
  accountName    String?
  accountAvatar  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("github_installations")
}

model Project {
  id            String   @id @default(uuid())
  userId        String
  name          String
  repoUrl       String
  defaultBranch String   @default("main")
  visibility    String   @default("private")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orgId        String?
  user         User          @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  runs         Run[]

  @@index([userId])
  @@index([orgId])
  @@map("projects")
}

model Run {
  id                  String    @id @default(uuid())
  projectId           String
  userId              String
  status              String    @default("created")
  gpuType             String
  gpuCount            Int       @default(1)
  hoursMax            Int       @default(2)
  command             String
  envJson             String?
  artifactPathsJson   String?
  upstreamInstanceId  String?   @unique
  billedSeconds       Int       @default(0)
  stripeUsageReported Boolean   @default(false)
  version             String?
  infraStartedAt      DateTime?
  infraFinishedAt     DateTime?
  startedAt           DateTime?
  finishedAt          DateTime?
  exitCode            Int?
  errorMessage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  events        RunEvent[]
  logs          RunLog[]
  artifacts     Artifact[]
  agentSessions AgentSession[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("runs")
}

model RunEvent {
  id        String   @id @default(uuid())
  runId     String
  type      String
  payload   String
  createdAt DateTime @default(now())

  run Run @relation(fields: [runId], references: [id])

  @@index([runId])
  @@map("run_events")
}

model RunLog {
  id        String   @id @default(uuid())
  runId     String
  stream    String
  line      String
  seq       Int
  createdAt DateTime @default(now())

  run Run @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([seq])
  @@map("run_logs")
}

model Artifact {
  id          String   @id @default(uuid())
  runId       String
  path        String
  kind        String
  bytes       BigInt   @default(0)
  sha256      String?
  storageKey  String?
  downloadUrl String?
  createdAt   DateTime @default(now())

  run Run @relation(fields: [runId], references: [id])

  @@index([runId])
  @@map("artifacts")
}

model AgentSession {
  id                       String    @id @default(uuid())
  runId                    String
  agentVersion             String
  capabilitiesJson         String?
  systemInfoJson           String?
  heartbeatIntervalSeconds Int       @default(5)
  lastHeartbeatAt          DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  run Run @relation(fields: [runId], references: [id])

  @@index([runId])
  @@map("agent_sessions")
}

model Workspace {
  id             String  @id @default(uuid())
  status         String
  region         String  @default("US")
  gpuType        String
  gpuCount       Int     @default(1)
  imageType      String  @default("BASE_ML_V1")
  isWarmPool     Boolean @default(false)
  assignedUserId String?

  // Proxmox backing
  proxmoxNode  String?
  proxmoxVmid  Int?
  vmInternalIp String?

  // Gateway exposure
  gatewayHost String?
  portSsh     Int?
  portJupyter Int?
  portVscode  Int?

  connectSshCommand String?
  connectJupyterUrl String?
  connectVscodeUrl  String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedAt   DateTime?
  startedAt    DateTime? // When workspace reached RUNNING
  terminatedAt DateTime?
  failedAt     DateTime? // When workspace reached FAILED

  // Provisioning tracking
  provisionStartedAt DateTime?
  cloneCompletedAt   DateTime?
  gpuAttachedAt      DateTime?
  bootCompletedAt    DateTime?
  ipDiscoveredAt     DateTime?
  agentRegisteredAt  DateTime?

  // Connection tracking
  firstConnectAt DateTime?
  lastConnectAt  DateTime?
  connectCount   Int       @default(0)

  verificationStatus    String    @default("PENDING")
  verificationScore     Int?
  lastHealthCheckAt     DateTime?
  lastAgentHeartbeatAt  DateTime?
  lastGpuUtilizationPct Int?
  lastGpuMemUsedMb      Int?
  lastGpuTempC          Int?
  lastCpuPct            Int?
  lastMemUsedMb         Int?
  lastDiskUsedMb        Int?
  lastNetworkRxMb       Int?
  lastNetworkTxMb       Int?

  // Error tracking
  lastErrorCode           String?
  lastErrorMessage        String?
  maxDurationMinutes      Int? // Auto-terminate after N minutes (null = unlimited)
  terminationReason       String? // idle, manual, failed, billing, budget_limit
  launchOperationKey      String?

  // Custom Docker image support
  customImageRepo       String?
  customImageTag        String?   @default("latest")
  registryCredentialId  String?
  registryCredential    ImageRegistryCredential? @relation(fields: [registryCredentialId], references: [id])

  // Spot price locked at launch time (for cold workspaces billed at checkout price)
  lockedSpotPriceCents    Int?

  // Network isolation: VLAN tag derived from org/user for tenant separation
  vlanTag                 Int?
  // S3 object storage: per-workspace MinIO bucket credentials
  s3BucketName            String?
  s3AccessKeyId           String?
  s3SecretAccessKeyEnc    String?   // AES-256-GCM encrypted

  cleanupAttemptCount     Int       @default(0)
  cleanupLastAttemptAt    DateTime?
  cleanupNextRetryAt      DateTime?
  cleanupLastErrorCode    String?
  cleanupLastErrorMessage String?

  orgId            String?
  assignedUser     User?                       @relation(fields: [assignedUserId], references: [id])
  organization     Organization?               @relation(fields: [orgId], references: [id])
  verifications    WorkspaceVerification[]
  usageSessions    UsageSession[]
  gpuAllocation    WorkspaceGpuAllocation?
  endpoint         WorkspaceEndpoint?
  experienceEvents ExperienceEvent[]
  launchOperation  WorkspaceLaunchOperation?   @relation("WorkspaceLaunchOperationWorkspace")
  cleanupJob       WorkspaceCleanupJob?        @relation("WorkspaceCleanupJobWorkspace")
  meterEvents      WorkspaceMeterEventOutbox[]
  attachedVolume   PersistentVolume?
  exposedPorts     ExposedPort[]

  @@index([status])
  @@index([status, updatedAt])
  @@index([assignedUserId])
  @@index([assignedUserId, status])
  @@index([isWarmPool])
  @@index([createdAt])
  @@index([startedAt])
  @@index([gpuType, status])
  @@index([proxmoxNode, status])
  @@index([status, cleanupNextRetryAt])
  @@index([orgId])
  @@map("workspaces")
}

model WorkspaceLaunchOperation {
  id               String   @id @default(cuid())
  userId           String
  operationKey     String
  requestHash      String
  workspaceId      String?
  status           String   @default("PROCESSING") // PROCESSING | COMPLETED | FAILED
  lastErrorCode    String?
  lastErrorMessage String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation("WorkspaceLaunchOperationWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, operationKey])
  @@unique([workspaceId])
  @@index([status, updatedAt])
  @@map("workspace_launch_operations")
}

model WorkspaceCleanupJob {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  reasonCode       String
  status           String    @default("PENDING") // PENDING | RUNNING | RETRY | FAILED | DONE
  attemptCount     Int       @default(0)
  maxAttempts      Int       @default(20)
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime?
  lastErrorCode    String?
  lastErrorMessage String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  workspace Workspace @relation("WorkspaceCleanupJobWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([status, updatedAt])
  @@map("workspace_cleanup_jobs")
}

model WorkspaceVerification {
  id                String   @id @default(uuid())
  workspaceId       String
  ranAt             DateTime @default(now())
  gpuName           String?
  vramGb            Decimal?
  cudaVersion       String?
  driverVersion     String?
  diskReadMbS       Decimal?
  diskWriteMbS      Decimal?
  netDownMbps       Decimal?
  netUpMbps         Decimal?
  microTrainSeconds Decimal?
  score0100         Int
  pass              Boolean
  rawLog            String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([ranAt])
  @@map("workspace_verifications")
}

model UsageSession {
  id                    String    @id @default(uuid())
  userId                String
  workspaceId           String
  gpuType               String?
  startTime             DateTime
  endTime               DateTime?
  totalSeconds          Int       @default(0)
  billedSeconds         Int       @default(0)
  pricePerHourCents     Int       @default(0)
  billedCents           Int       @default(0)
  stripePaymentIntentId String?
  stripeMeterEventId    String?
  status                String    @default("RUNNING")

  user        User                       @relation(fields: [userId], references: [id])
  workspace   Workspace                  @relation(fields: [workspaceId], references: [id])
  meterOutbox WorkspaceMeterEventOutbox?

  @@index([userId])
  @@index([userId, startTime])
  @@index([workspaceId])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([gpuType, startTime])
  @@map("usage_sessions")
}

model WorkspaceMeterEventOutbox {
  id                 String    @id @default(cuid())
  usageSessionId     String    @unique
  userId             String
  workspaceId        String
  eventName          String    @default("gpu_seconds")
  valueSeconds       Int
  status             String    @default("PENDING") // PENDING | RETRY | SENT | FAILED
  attemptCount       Int       @default(0)
  maxAttempts        Int       @default(20)
  lastAttemptAt      DateTime?
  nextAttemptAt      DateTime?
  stripeMeterEventId String?
  lastErrorCode      String?
  lastErrorMessage   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sentAt             DateTime?

  usageSession UsageSession @relation(fields: [usageSessionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("workspace_meter_event_outbox")
}

model FleetNode {
  id                String    @id @default(uuid())
  name              String    @unique
  apiHost           String
  status            String    @default("ACTIVE")
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime?
  lastHealthCheckAt DateTime?

  // Node health metrics
  loadAverage   Decimal?
  memoryUsedPct Int?
  diskUsedPct   Int?
  diskFreeGb    Int?
  vmCount       Int?
  warmVmCount   Int?

  // Failure tracking
  provisionFailures24h Int       @default(0)
  lastProvisionFailAt  DateTime?

  gpus           FleetGpu[]
  gpuAllocations WorkspaceGpuAllocation[]

  @@index([status])
  @@map("fleet_nodes")
}

model FleetGpu {
  id                     String    @id @default(uuid())
  nodeId                 String
  gpuName                String
  gpuType                String? // RTX_5090, A100_80GB
  pciAddress             String
  vramGb                 Decimal?
  serial                 String?
  status                 String    @default("FREE")
  failureCount           Int       @default(0)
  lastVerificationPassAt DateTime?
  lastVerificationFailAt DateTime?
  createdAt              DateTime  @default(now())
  lastSeenAt             DateTime?

  // Health metrics from heartbeat
  lastTempC      Int?
  lastUtilPct    Int?
  lastMemUsedMb  Int?
  eccErrors24h   Int       @default(0)
  lastEccErrorAt DateTime?

  // Current allocation
  currentWorkspaceId String?

  node       FleetNode               @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  allocation WorkspaceGpuAllocation?

  @@unique([nodeId, pciAddress])
  @@index([status])
  @@index([status, gpuType])
  @@index([nodeId, status])
  @@map("fleet_gpus")
}

model VmTemplate {
  id           String   @id @default(uuid())
  proxmoxNode  String
  templateVmid Int
  name         String
  gpuType      String?
  region       String   @default("US")
  imageVersion String?
  diskSizeGb   Int?
  memorySizeMb Int?
  cpuCores     Int?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([proxmoxNode, templateVmid])
  @@index([gpuType, region])
  @@map("vm_templates")
}

model WorkspaceGpuAllocation {
  id          String    @id @default(uuid())
  workspaceId String    @unique
  gpuId       String    @unique
  nodeId      String
  allocatedAt DateTime  @default(now())
  releasedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  gpu       FleetGpu  @relation(fields: [gpuId], references: [id])
  node      FleetNode @relation(fields: [nodeId], references: [id])

  @@map("workspace_gpu_allocations")
}

model WorkspaceEndpoint {
  id          String    @id @default(uuid())
  workspaceId String    @unique
  gatewayHost String
  sshPort     Int       @unique
  jupyterPort Int       @unique
  vscodePort  Int       @unique
  allocatedAt DateTime  @default(now())
  releasedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_endpoints")
}

model SecurityLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String?
  eventType String
  ip        String?
  userAgent String?
  eventData String?

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([eventType])
  @@index([userId])
  @@map("security_logs")
}

model AuthorPost {
  id                 String    @id @default(uuid())
  title              String
  slug               String    @unique
  excerpt            String?
  bodyMarkdown       String
  bodyHtml           String?
  visibility         String
  status             String    @default("DRAFT")
  tags               String    @default("[]")
  coverImageUrl      String?
  ctaText            String?
  ctaUrl             String?
  seoTitle           String?
  seoDescription     String?
  scheduledPublishAt DateTime?
  publishedAt        DateTime?
  createdByUserId    String
  updatedByUserId    String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now())

  createdBy User                 @relation("CreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User                 @relation("UpdatedBy", fields: [updatedByUserId], references: [id])
  revisions AuthorPostRevision[]

  @@index([status])
  @@index([visibility])
  @@index([publishedAt])
  @@map("author_posts")
}

model AuthorPostRevision {
  id              String   @id @default(uuid())
  postId          String
  title           String
  excerpt         String?
  bodyMarkdown    String
  updatedByUserId String
  createdAt       DateTime @default(now())

  post      AuthorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  updatedBy User       @relation(fields: [updatedByUserId], references: [id])

  @@index([postId])
  @@map("author_post_revisions")
}

model AppBanner {
  id              String    @id @default(uuid())
  enabled         Boolean   @default(false)
  message         String?
  severity        String    @default("INFO")
  linkText        String?
  linkUrl         String?
  startAt         DateTime?
  endAt           DateTime?
  updatedByUserId String
  updatedAt       DateTime  @default(now())

  updatedBy User @relation(fields: [updatedByUserId], references: [id])

  @@map("app_banner")
}

model AuthorAudit {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  actorUserId String
  action      String
  targetType  String?
  targetId    String?
  diffJson    String?

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([createdAt])
  @@index([actorUserId])
  @@map("author_audit")
}

model WarmPoolConfig {
  id                    String    @id @default(uuid())
  region                String    @default("US")
  gpuType               String
  targetCount           Int       @default(1)
  createdAt             DateTime  @default(now())
  basePriceCents        Int       @default(55) // base price in cents/hr
  currentSpotPriceCents Int       @default(55) // dynamic spot price
  lastPriceUpdateAt     DateTime?
  lastRentalAt          DateTime? // last time a warm workspace was rented from this pool

  @@unique([region, gpuType])
  @@map("warm_pool_config")
}

model GpuSku {
  id                String   @id @default(uuid())
  key               String   @unique
  displayName       String
  pricePerHourCents Int
  vramGb            Int
  shortBadge        String
  descriptionLines  String   @default("[]")
  enabled           Boolean  @default(true)
  spotPriceCents    Int?     // current spot price (mirrors WarmPoolConfig)
  spotMultiplier    Float    @default(1.0) // current multiplier (0.85 - 2.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("gpu_skus")
}

// =============================================================================
// Author Portal: Experience Events
// =============================================================================
// Lightweight events for tracking user journey and experience metrics
model ExperienceEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  userId      String?
  workspaceId String?
  type        String // auth.login_success, workspace.created, connect.ssh_success, etc.
  metadata    String? // JSON with event-specific data
  requestId   String? // For correlating events in a request
  clientIp    String? // Hashed for privacy
  latencyMs   Int? // For timing events
  errorCode   String? // For failure events
  protocol    String? // ssh, jupyter, vscode (for connect events)
  result      String? // success, fail

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([type, createdAt])
  @@map("experience_events")
}

// =============================================================================
// Event Retention: Daily Rollups
// =============================================================================
// Aggregated event data for long-term history (raw events are deleted after 30 days)
model DailyEventRollup {
  id      String   @id @default(uuid())
  date    DateTime // The date being aggregated
  userId  String? // Per-user rollups (null for system-wide)
  gpuType String? // Per-GPU-type rollups

  // Event counts by type
  loginSuccessCount          Int @default(0)
  loginFailCount             Int @default(0)
  workspaceCreatedCount      Int @default(0)
  workspaceStartedCount      Int @default(0)
  workspaceFailedCount       Int @default(0)
  workspaceTerminatedCount   Int @default(0)
  connectSshSuccessCount     Int @default(0)
  connectSshFailCount        Int @default(0)
  connectJupyterSuccessCount Int @default(0)
  connectJupyterFailCount    Int @default(0)
  billingMeterEmittedCount   Int @default(0)
  billingMeterFailCount      Int @default(0)

  // Timing metrics (averages)
  avgProvisionLatencyMs Float?
  avgConnectLatencyMs   Float?

  // Usage totals
  totalGpuSeconds  Int @default(0)
  totalBilledCents Int @default(0)

  createdAt DateTime @default(now())

  @@unique([date, userId, gpuType])
  @@index([date])
  @@index([userId, date])
  @@map("daily_event_rollups")
}

// =============================================================================
// Author Portal: Incidents
// =============================================================================
// Auto-generated and manual incidents for ops visibility
model Incident {
  id          String    @id @default(uuid())
  type        String // provision_failure_spike, orphan_vm_detected, etc.
  severity    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title       String
  description String?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  count       Int       @default(1)
  status      String    @default("OPEN") // OPEN, ACKED, RESOLVED
  resolvedAt  DateTime?
  ownerId     String? // Author who acknowledged
  notes       String?

  // Affected resources (JSON arrays)
  affectedWorkspaceIds String? // JSON array
  affectedNodeIds      String? // JSON array
  affectedGpuIds       String? // JSON array

  @@index([status, lastSeenAt])
  @@index([type, firstSeenAt])
  @@index([severity])
  @@map("incidents")
}

// =============================================================================
// Author Portal: Worker Leader Tracking
// =============================================================================
model WorkerLeader {
  id           Int       @id @default(1)
  workerId     String
  fencingToken String
  acquiredAt   DateTime  @default(now())
  lastTickAt   DateTime?

  @@map("worker_leader")
}

// =============================================================================
// Author Portal: Configuration Change Tracking
// =============================================================================
model ConfigChange {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  actorId    String? // User who made change (null for system)
  configType String // warm_pool, idle_policy, pricing, etc.
  configKey  String
  oldValue   String?
  newValue   String?
  reason     String?

  @@index([createdAt])
  @@index([configType])
  @@map("config_changes")
}

// =============================================================================
// Author Portal: Deploy Versions
// =============================================================================
model DeployVersion {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  service    String // api, worker, gateway
  version    String
  commitHash String?
  deployedBy String?

  @@index([service, createdAt])
  @@map("deploy_versions")
}

// =============================================================================
// Teams & Organizations
// =============================================================================
model Organization {
  id                           String   @id @default(uuid())
  name                         String
  slug                         String   @unique
  stripeCustomerId             String?
  stripeDefaultPaymentMethodId String?
  billingEmail                 String?
  plan                         String   @default("TEAM")
  maxMembers                   Int      @default(5)
  maxActiveWorkspaces          Int      @default(5)
  maxConcurrentRuns            Int      @default(10)
  monthlySoftLimitCents        Int?
  hardLimitAction              String   @default("ALERT") // ALERT | AUTO_TERMINATE
  lastBudgetAlertAt            DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  memberships OrgMembership[]
  invitations OrgInvitation[]
  workspaces  Workspace[]
  projects    Project[]

  @@map("organizations")
}

model OrgMembership {
  id          String    @id @default(uuid())
  orgId       String
  userId      String
  role        String    @default("MEMBER") // OWNER | ADMIN | MEMBER
  invitedById String?
  invitedAt   DateTime  @default(now())
  acceptedAt  DateTime?
  status      String    @default("PENDING") // PENDING | ACTIVE | REMOVED
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  user      User         @relation("OrgMembershipUser", fields: [userId], references: [id])
  invitedBy User?        @relation("OrgMembershipInvitedBy", fields: [invitedById], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("org_memberships")
}

model OrgInvitation {
  id          String    @id @default(uuid())
  orgId       String
  email       String
  role        String    @default("MEMBER") // ADMIN | MEMBER
  invitedById String
  tokenHash   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  invitedBy User         @relation("OrgInvitationInvitedBy", fields: [invitedById], references: [id])

  @@unique([orgId, email])
  @@map("org_invitations")
}

// =============================================================================
// Public Developer API: API Keys & Webhooks
// =============================================================================

model ApiKey {
  id              String    @id @default(uuid())
  userId          String
  organizationId  String?
  name            String    @default("Default")
  keyPrefix       String    // first 8 chars of key for identification (e.g. "ak_live_")
  keyHash         String    @unique // SHA-256 hash of the full key
  scopes          String    @default("*") // comma-separated scopes
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])

  @@index([keyHash])
  @@index([userId])
  @@map("api_keys")
}

model WebhookEndpoint {
  id              String    @id @default(uuid())
  userId          String
  organizationId  String?
  url             String
  secret          String    // HMAC signing secret
  events          String    // JSON array of event types like ["run.completed","workspace.failed"]
  enabled         Boolean   @default(true)
  failureCount    Int       @default(0)
  lastDeliveredAt DateTime?
  lastFailedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  deliveries      WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id              String    @id @default(uuid())
  endpointId      String
  event           String    // e.g. "run.completed"
  payload         String    // JSON payload
  responseStatus  Int?
  responseBody    String?
  attemptCount    Int       @default(1)
  deliveredAt     DateTime?
  nextRetryAt     DateTime?
  status          String    @default("PENDING") // PENDING, DELIVERED, FAILED
  createdAt       DateTime  @default(now())

  endpoint        WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId])
  @@index([status])
  @@map("webhook_deliveries")
}

// =============================================================================
// Persistent Network Volumes
// =============================================================================
model PersistentVolume {
  id                    String    @id @default(uuid())
  userId                String
  organizationId        String?
  name                  String
  sizeGb                Int
  status                String    @default("CREATING") // CREATING, AVAILABLE, IN_USE, DELETING, DELETED, FAILED
  proxmoxNode           String?
  proxmoxDiskId         String?   // e.g., "vm-9001-disk-0"
  proxmoxStoragePool    String?   @default("local-lvm")
  attachedToWorkspaceId String?   @unique
  lastAttachedAt        DateTime?
  lastDetachedAt        DateTime?
  usedBytes             BigInt    @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id])
  attachedWorkspace     Workspace? @relation(fields: [attachedToWorkspaceId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("persistent_volumes")
}

// =============================================================================
// Custom Docker Images & Private Registries
// =============================================================================
model ImageRegistryCredential {
  id              String    @id @default(uuid())
  userId          String
  name            String    @default("Default Registry")
  registryUrl     String    // e.g., "https://index.docker.io/v1/", "123456789.dkr.ecr.us-east-1.amazonaws.com"
  registryType    String    @default("DOCKER_HUB") // DOCKER_HUB, AWS_ECR, GCP_GCR, GITHUB_GHCR, CUSTOM
  username        String?
  encryptedToken  String    // encrypted at rest
  verified        Boolean   @default(false)
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  workspaces      Workspace[]

  @@index([userId])
  @@map("image_registry_credentials")
}

// =============================================================================
// Public Port Gateway: Exposed Ports (Zero Trust Tunnels)
// =============================================================================
model ExposedPort {
  id              String    @id @default(uuid())
  workspaceId     String
  userId          String
  internalPort    Int       // e.g., 7860 for Gradio
  publicSubdomain String    @unique // e.g., "ws-abc123-7860"
  publicUrl       String    // e.g., "https://ws-abc123-7860.aldaro.ai"
  accessMode      String    @default("PRIVATE") // PUBLIC or PRIVATE
  protocol        String    @default("HTTP") // HTTP, TCP
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime  @default(now())
  releasedAt      DateTime?

  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, internalPort])
  @@index([workspaceId])
  @@index([publicSubdomain])
  @@map("exposed_ports")
}

// =============================================================================
// Support Ticketing & Refunds
// =============================================================================
model SupportTicket {
  id              String    @id @default(uuid())
  userId          String
  workspaceId     String?
  usageSessionId  String?
  subject         String
  description     String
  status          String    @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  priority        String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  category        String?   // gpu_crash, billing, network, general
  assignedToId    String?
  refundedCents   Int?      // amount refunded via Stripe
  refundedAt      DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  messages        TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@index([assignedToId])
  @@map("support_tickets")
}

model TicketMessage {
  id              String    @id @default(uuid())
  ticketId        String
  authorId        String
  body            String
  isInternal      Boolean   @default(false) // internal notes visible only to ops
  createdAt       DateTime  @default(now())

  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author          User          @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

// =============================================================================
// Budget Alerts
// =============================================================================
model BudgetAlert {
  id              String    @id @default(uuid())
  userId          String
  mtdSpendCents   Int       // month-to-date spend at alert time
  limitCents      Int       // the limit that was breached
  thresholdPct    Int       // 90, 100, etc.
  action          String    // ALERT | AUTO_TERMINATE
  notifiedAt      DateTime  @default(now())
  workspacesTerminated Int  @default(0) // count of auto-terminated workspaces

  @@index([userId])
  @@index([notifiedAt])
  @@map("budget_alerts")
}

// =============================================================================
// Hybrid Cloud Burst Nodes
// =============================================================================
model BurstNode {
  id                String    @id @default(uuid())
  provider          String    // LAMBDA, HETZNER, RUNPOD
  providerInstanceId String?  @unique // provider's instance/server ID
  region            String    @default("US")
  gpuType           String
  gpuCount          Int       @default(1)
  status            String    @default("PROVISIONING") // PROVISIONING | JOINING | ACTIVE | DRAINING | TERMINATED | FAILED
  proxmoxNodeName   String?   // name once joined to cluster
  hourlyRateCents   Int       @default(0)
  triggerReason     String?   // warm_pool_exhausted, demand_surge
  provisionedAt     DateTime  @default(now())
  joinedAt          DateTime?
  drainingAt        DateTime?
  terminatedAt      DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([provider, status])
  @@map("burst_nodes")
}

// =============================================================================
// Clone Semaphore: track in-flight clones per Proxmox node
// =============================================================================
model CloneSemaphore {
  id            String    @id @default(uuid())
  proxmoxNode   String
  workspaceId   String    @unique
  acquiredAt    DateTime  @default(now())
  releasedAt    DateTime?

  @@index([proxmoxNode, releasedAt])
  @@map("clone_semaphores")
}

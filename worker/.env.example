# Aldaro Worker Environment Variables
# Copy to .env and fill in values - NEVER commit .env

NODE_ENV=development

# Database (same as API, Postgres in production)
DATABASE_URL=postgresql://user:password@localhost:5432/aldaro

# Redis
REDIS_URL=redis://localhost:6379

# Agent authentication - MUST match API
ALDARO_AGENT_SHARED_SECRET=

# Worker settings
AUTO_TERMINATE_IDLE_MINUTES=20
WARM_POOL_TICK_SECONDS=30

# API for callbacks
API_BASE_URL=http://localhost:4000

# Proxmox Fleet (Aldaro-owned infrastructure only)
PROXMOX_API_URL=https://proxmox.aldaro.internal:8006
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=

# Workspace image
ALDARO_IMAGE=aldaro/workspace-base:latest

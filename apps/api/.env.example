# Aldaro API Environment Variables
# Copy to .env and fill in values - NEVER commit .env

NODE_ENV=development

# Server
API_PORT=4000
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Database (Postgres in production)
DATABASE_URL=postgresql://user:password@localhost:5432/aldaro

# Redis (for rate limiting, sessions)
REDIS_URL=redis://localhost:6379

# JWT Secrets - MUST be 32+ chars (64+ recommended). Rotate regularly.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Cookie settings
COOKIE_DOMAIN=localhost

# Agent authentication - MUST be rotated
ALDARO_AGENT_SHARED_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Proxmox Fleet (Aldaro-owned infrastructure only)
PROXMOX_API_URL=https://proxmox.aldaro.internal:8006
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=
PROXMOX_DEFAULT_NODE=pve1

# Gateway service
GATEWAY_INTERNAL_URL=http://gateway.aldaro.internal:5001
GATEWAY_SERVICE_SECRET=

# Workspace image
ALDARO_IMAGE=aldaro/workspace-base:latest

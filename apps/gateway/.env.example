# Aldaro Gateway Environment Variables

NODE_ENV=development

# Gateway port
GATEWAY_PORT=5001

# Public-facing gateway hostname (returned in allocation responses)
GATEWAY_HOST=gw1.aldaro.ai

# HMAC secret for authenticating internal requests from API/worker
# Must match GATEWAY_SERVICE_SECRET in API and worker .env
# Generate with: openssl rand -hex 32
GATEWAY_SERVICE_SECRET=
